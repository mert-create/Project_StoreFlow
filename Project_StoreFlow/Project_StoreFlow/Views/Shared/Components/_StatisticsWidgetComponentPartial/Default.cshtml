<div class="main-panel">
	<div class="content-wrapper">

		<div class="row">
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">Kategoriler</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.CategoryCount</h2>

								</div>
								<small class="text-gray">Toplamda @ViewBag.CategoryCount Kategori Bulunmaktadır.</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-chart-pie text-info icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">En Yüksek Ürün Fiyatı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.ProductMaxPrice TL</h2>

								</div>
								<small class="text-gray">Bu ürün: @ViewBag.productMaxPriceProductName</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-shopping-cart text-danger icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">En Düşük Ürün Fiyatı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.ProductMinPrice TL</h2>

								</div>
								<small class="text-gray">Bu ürün: @ViewBag.productMinPriceProductName</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-bell text-info icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="row">
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">Toplam Ürün Stok Sayısı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.totalSumProductStock</h2>

								</div>
								<small class="text-gray">Stokta @ViewBag.totalSumProductStock ürün bulunuyor..</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-comment text-warning icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">Ortalama Ürün Stok Sayısı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@(((double)ViewBag.avarageProductStock).ToString("N2"))</h2>
								</div>
								<small class="text-gray">Toplam Ürün Sayısı / Ürün Adet Değeri</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-cubes text-primary icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">Ortalama Ürün Fiyatı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@(((double)ViewBag.avarageProductPrice).ToString("N2")) TL</h2>
								</div>
								<small class="text-gray">1 Adet Ürün İçin Ortalama Fiyat</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-desktop text-secondary icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="row">
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">1000 TL'den Yüksek Fiyatlı Ürün Sayısı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.biggerPriceThen1000ProductCount</h2>

								</div>
								<small class="text-gray">Fiyatı 1000 TL'den Yüksek Ürün Sayısı</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-clock text-success icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">54 Nolu ID'ye Ait Ürün Adı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.getIDIs54ProductName</h2>
								</div>
								<small class="text-gray">ID Değeri 54 Olan Ürün Adı</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-coffee text-dark icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
			<div class="col-md-4 grid-margin">
				<div class="card">
					<div class="card-body">
						<h4 class="card-title mb-0">Stok Sayısı 50-100 Arasındaki Ürün Sayısı</h4>
						<div class="d-flex justify-content-between align-items-center">
							<div class="d-inline-block pt-3">
								<div class="d-md-flex">
									<h2 class="mb-0">@ViewBag.stockCountBıgger50AndSmaller100ProductCount</h2>
								</div>
								<small class="text-gray">Stok Sayısı 50'den Büyük Ve 100'den Küçük Ürün Sayısı</small>
							</div>
							<div class="d-inline-block">
								<i class="fas fa-filter text-primary icon-lg"></i>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>

		 
	</div>
	 
	<footer class="footer">
		<div class="d-sm-flex justify-content-center justify-content-sm-between">
			<span class="text-muted text-center text-sm-left d-block d-sm-inline-block">Copyright © 2018 <a href="https://www.urbanui.com/" target="_blank">Urbanui</a>. All rights reserved.</span>
			<span class="float-none float-sm-right d-block mt-1 mt-sm-0 text-center">Hand-crafted & made with <i class="far fa-heart text-danger"></i></span>
		</div>
	</footer>
 
</div>
