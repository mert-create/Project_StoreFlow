@model IEnumerable<dynamic>
@{
	ViewData["Title"] = "CustomerListWithIndex";
	Layout = "~/Views/Layout/Index.cshtml";
}



<div class="row">
	<div class="col-lg-12 grid-margin stretch-card">
		<div class="card">
			<div class="card-body">
				<h4 class="card-title">Müşteri Listesi İndex</h4>
				<div class="table-responsive">
					<table class="table">
						<thead>
							<tr>
								<th>#</th>
								<th>Müşteri Adı</th>
								<th>Müşteri Soyadı</th>
								<th>Müşteri Şehri</th>
							</tr>
						</thead>
						<tbody>
							@foreach (var item in Model)
							{
								<tr>
									<td>@item.SiraNo</td>
									<td>@item.CustomerName</td>
									<td>@item.CustomerSurname</td>
									<td>@item.CustomerCity</td>
									
								</tr>
							}
						</tbody>
					</table>
 
				</div>
			</div>
		</div>
	</div>

</div>